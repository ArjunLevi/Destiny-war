# Coinbase Developer Platform / OnchainKit API key
NEXT_PUBLIC_ONCHAINKIT_API_KEY=

# Public URL of your deployment
NEXT_PUBLIC_URL=https://destinywar.app

# Unified Destiny War hub on Base (mint + energy + upgrades + spin + weekly rank)
NEXT_PUBLIC_DESTINY_HUB_ADDRESS=

# Legacy aliases (optional — hub address is used if DESTINY_HUB is empty)
NEXT_PUBLIC_HERO_MINT_ADDRESS=
NEXT_PUBLIC_DAILY_STRIKE_ADDRESS=

# Chain ID (8453 = Base mainnet)
NEXT_PUBLIC_CHAIN_ID=8453
